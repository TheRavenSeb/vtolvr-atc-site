<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="METAR Input - Air Traffic Control Weather Report">
    <title>METAR Report</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
            overflow-x: hidden;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
            width: calc(100% - 280px);
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 999;
            transition: transform 0.3s ease-in-out;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .close-sidebar-btn {
            display: none;
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            z-index: 1002;
        }

        .close-sidebar-btn:hover {
            color: #667eea;
        }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.5em;
            cursor: pointer;
            padding: 10px 0;
            margin-bottom: 20px;
            transition: all 0.2s;
            margin-right: 15px;
        }

        .hamburger-btn:hover {
            color: #667eea;
        }

        .hamburger-btn.active {
            color: #667eea;
        }

        .header-top {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-logo img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        .container {
            width: 100%;
            max-width: 600px;
            background: rgba(51, 51, 51, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(102, 126, 234, 0.3);
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 20px;
        }

        header h1 {
            font-size: 2.5em;
            color: #667eea;
            margin-bottom: 10px;
        }

        header p {
            color: #b0b0b0;
            font-size: 1em;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            display: block;
            color: #e0e0e0;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 1.05em;
        }

        .form-label span {
            color: #f44336;
            margin-left: 5px;
        }

        .input-wrapper {
            display: flex;
            gap: 10px;
            align-items: flex-end;
        }

        .form-input {
            flex: 1;
            padding: 12px;
            background-color: #2a2a2a;
            border: 2px solid #667eea;
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 1em;
            transition: all 0.3s;
        }

        .form-input:focus {
            outline: none;
            border-color: #7f9eff;
            box-shadow: 0 0 12px rgba(102, 126, 234, 0.4);
        }

        .form-input::placeholder {
            color: #888;
        }

        .unit-label {
            color: #b0b0b0;
            font-size: 0.9em;
            white-space: nowrap;
            padding: 12px;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px;
            background-color: #2a2a2a;
            border: 2px solid #667eea;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .checkbox-group:hover {
            background-color: #333;
            border-color: #7f9eff;
        }

        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #667eea;
        }

        .checkbox-group label {
            flex: 1;
            cursor: pointer;
            font-size: 1em;
            color: #e0e0e0;
            margin: 0;
        }

        .form-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(102, 126, 234, 0.2);
        }

        .form-section:last-of-type {
            border-bottom: none;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 1.2em;
            color: #667eea;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 35px;
        }

        .btn {
            flex: 1;
            padding: 14px;
            border: none;
            border-radius: 6px;
            font-size: 1.05em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-submit {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-reset {
            background: rgba(102, 126, 234, 0.2);
            color: #667eea;
            border: 2px solid #667eea;
        }

        .btn-reset:hover {
            background: #667eea;
            color: white;
        }

        .success-message {
            display: none;
            background-color: #4CAF50;
            color: white;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
        }

        .success-message.show {
            display: block;
        }

        .error-message {
            display: none;
            background-color: #f44336;
            color: white;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
        }

        .error-message.show {
            display: block;
        }

        @media (max-width: 1024px) {
            .container {
                padding: 25px;
            }
        }

        @media (max-width: 768px) {
            .hamburger-btn {
                display: block;
            }

            .main-content {
                width: 100%;
                padding: 15px;
            }

            .sidebar {
                width: 250px;
                height: auto;
                position: fixed;
                top: 0;
                left: 0;
                transform: translateX(-100%);
                padding: 70px 20px 20px 20px;
                z-index: 1001;
                max-height: 100vh;
                overflow-y: auto;
                border-right: 1px solid #444;
                transition: transform 0.3s ease-in-out;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .close-sidebar-btn {
                display: block;
            }

            .container {
                padding: 25px;
            }

            header h1 {
                font-size: 2em;
            }

            header p {
                font-size: 0.95em;
            }

            .input-wrapper {
                flex-direction: column;
                align-items: stretch;
            }

            .unit-label {
                padding: 8px;
            }

            .form-input {
                padding: 12px;
                font-size: 16px;
            }

            .button-group {
                flex-direction: column;
                gap: 10px;
            }

            .form-label {
                font-size: 1em;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 20px;
            }

            header h1 {
                font-size: 1.7em;
                margin-bottom: 8px;
            }

            header p {
                font-size: 0.9em;
            }

            .form-group {
                margin-bottom: 20px;
            }

            .form-label {
                font-size: 0.95em;
                margin-bottom: 8px;
            }

            .form-input {
                padding: 12px;
                font-size: 16px;
            }

            .checkbox-group {
                padding: 12px;
                border-radius: 4px;
            }

            .checkbox-group input[type="checkbox"] {
                width: 18px;
                height: 18px;
            }

            .btn {
                padding: 12px;
                font-size: 1em;
            }

            .section-title {
                font-size: 1.1em;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <button type="button" class="close-sidebar-btn" id="closeSidebarBtn" onclick="closeSidebar()" aria-label="Close sidebar">✕</button>
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item" href="/applications">Applications</a>
            <a class="sidebar-menu-item active" href="/atc/metar">METAR</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
    </div>

    <div class="main-content">
        <div class="header-top">
            <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()">☰</button>
        </div>
        <div class="container">
        <header>
            <h1>METAR Report</h1>
            <p>Submit weather conditions for air traffic control</p>
        </header>

        <div id="successMessage" class="success-message">METAR report submitted successfully!</div>
        <div id="errorMessage" class="error-message"></div>

        <form id="metarForm">

            <div class="form-section">
                <h2 class="section-title">General Information</h2>
                
                <div class="form-group">
                    <label class="form-label">Report Timestamp</label>
                    <div class="input-wrapper">
                        <input type="text" class="form-input" id="reportTimestamp" value="<%= new Date().toLocaleString() %>" readonly>
                    </div>

                    <div style="margin-top: 10px; color: #888; font-size: 0.9em;">
                        (The timestamp is automatically generated when you submit the report)
                        </div>

                        <div class ="form-group" style="margin-top: 20px;">
                            <label class="form-label">Session ID </label>
                            <div class="input-wrapper">
                                <input type="text" class="form-input" id="sessionId" placeholder="Enter session ID if applicable" required>
                            </div>
                        </div>
                </div>


</div>
            <div class="form-section">
                <h2 class="section-title">Wind Information</h2>
                
                <div class="form-group">
                    <label class="form-label">Wind Direction <span>*</span></label>
                    <div class="input-wrapper">
                        <input type="number" class="form-input" id="windDirection" placeholder="000-360" min="0" max="360" required>
                        <span class="unit-label">°</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Wind Speed <span>*</span></label>
                    <div class="input-wrapper">
                        <input type="number" class="form-input" id="windSpeed" placeholder="0-100" min="0" max="100" step="0.1" required>
                        <span class="unit-label">knots</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Wind Gust (Optional)</label>
                    <div class="input-wrapper">
                        <input type="number" class="form-input" id="windGust" placeholder="0-100" min="0" max="100" step="0.1">
                        <span class="unit-label">knots</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h2 class="section-title">Visibility</h2>
                
                <div class="form-group">
                    <label class="form-label">Visibility <span>*</span></label>
                    <div class="input-wrapper">
                        <input type="number" class="form-input" id="visibility" placeholder="0-10" min="0" max="10" step="0.1" required>
                        <span class="unit-label">SM</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h2 class="section-title">Weather Conditions</h2>
                
                <div class="form-group">
                    <label class="checkbox-group">
                        <input type="checkbox" id="isRaining">
                        <label for="isRaining" style="flex: 1; margin: 0; cursor: pointer;">Currently Raining</label>
                    </label>
                </div>

                <div class="form-group">
                    <label class="form-label">Additional Weather Notes (Optional)</label>
                    <textarea class="form-input" id="weatherNotes" placeholder="e.g., Thunderstorms, Snow, Fog, etc." rows="4" style="resize: vertical;"></textarea>
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="btn btn-submit">Submit METAR Report</button>
                <button type="button" class="btn btn-reset" onclick="clearMetar()">Clear current METAR</button>
            </div>
        </form>
    </div>

    <script>
        const form = document.getElementById('metarForm');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');

        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            // Validate required fields
            const windDirection = document.getElementById('windDirection').value;
            const windSpeed = document.getElementById('windSpeed').value;
            const visibility = document.getElementById('visibility').value;

            if (!windDirection || !windSpeed || !visibility) {
                showError('Please fill in all required fields');
                return;
            }

            if (windDirection < 0 || windDirection > 360) {
                showError('Wind direction must be between 0 and 360 degrees');
                return;
            }

            if (windSpeed < 0 || windSpeed > 100) {
                showError('Wind speed must be between 0 and 100 knots');
                return;
            }

            if (visibility < 0 || visibility > 10) {
                showError('Visibility must be between 0 and 10 SM');
                return;
            }

            const metarData = {
                windDirection: parseInt(windDirection),
                windSpeed: parseFloat(windSpeed),
                windGust: document.getElementById('windGust').value ? parseFloat(document.getElementById('windGust').value) : null,
                visibility: parseFloat(visibility),
                isRaining: document.getElementById('isRaining').checked,
                weatherNotes: document.getElementById('weatherNotes').value || null,
                timestamp: new Date().toISOString(),
                sessionId: document.getElementById('sessionId').value.trim() || null
            };

            try {
                const response = await fetch('/api/metar/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(metarData)
                });

                if (!response.ok) {
                    throw new Error('Failed to submit METAR report');
                }

                showSuccess('METAR report submitted successfully!');
                form.reset();
                setTimeout(() => {
                    successMessage.classList.remove('show');
                }, 3000);
            } catch (error) {
                console.error('Error submitting METAR:', error);
                showError('Error submitting METAR report: ' + error.message);
            }
        });

        function clearMetar() {
            //send request to clear current METAR data for the session
            fetch('/api/metar/clear', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ sessionId: document.getElementById('sessionId').value.trim() || null })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Failed to clear METAR data');
                }
                return response.json();
            })
            .then(data => {
                showSuccess('Current METAR data cleared successfully!');
                form.reset();
            })
            .catch(error => {
                console.error('Error clearing METAR data:', error);
                showError('Error clearing METAR data: ' + error.message);
            });
            form.reset();
        }

        function showSuccess(message) {
            successMessage.textContent = message;
            successMessage.classList.add('show');
            errorMessage.classList.remove('show');
        }

        function showError(message) {
            errorMessage.textContent = message;
            errorMessage.classList.add('show');
            successMessage.classList.remove('show');
        }

        // Sidebar functionality
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            sidebar.classList.toggle('active');
            hamburgerBtn.classList.toggle('active');
            const closeBtn = document.getElementById('closeSidebarBtn');
            if (sidebar.classList.contains('active')) {
                closeBtn.style.display = 'block';
            } else {
                closeBtn.style.display = 'none';
            }
        }

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const closeBtn = document.getElementById('closeSidebarBtn');
            sidebar.classList.remove('active');
            hamburgerBtn.classList.remove('active');
            closeBtn.style.display = 'none';
        }

        // Close sidebar when menu item is clicked on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarMenuItems = document.querySelectorAll('.sidebar-menu-item');
            sidebarMenuItems.forEach(item => {
                item.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        closeSidebar();
                    }
                });
            });
        });
    </script>
</body>
</html>
