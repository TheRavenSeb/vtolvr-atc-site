<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title><%= title %></title>
	<link rel="stylesheet" href="/styles/style.css" />
	<style>
		.chart-maker-wrap {
			max-width: 1100px;
			margin: 2rem auto;
			padding: 1rem;
			color: #fff;
		}

		.chart-maker-grid {
			display: grid;
			grid-template-columns: 320px 1fr;
			gap: 1rem;
		}

		.card {
			background: #13151a;
			border: 1px solid #2a2f38;
			border-radius: 12px;
			padding: 1rem;
		}

		.card h2 {
			margin-top: 0;
			font-size: 1.1rem;
		}

		.field {
			display: flex;
			flex-direction: column;
			margin-bottom: 0.75rem;
			gap: 0.3rem;
		}

		label {
			font-size: 0.85rem;
			color: #b4bdcb;
		}

		input, select, textarea, button {
			border-radius: 8px;
			border: 1px solid #3a4352;
			background: #0f1217;
			color: #fff;
			padding: 0.55rem 0.65rem;
			font-size: 0.95rem;
		}

		textarea {
			resize: vertical;
			min-height: 80px;
			font-family: monospace;
		}

		button {
			cursor: pointer;
			background: #255eea;
			border: none;
			font-weight: 600;
			padding: 0.65rem;
			margin-top: 0.5rem;
		}

		#downloadBtn {
			background: #1b9c57;
		}

		#downloadBtn:disabled {
			background: #444;
			cursor: not-allowed;
		}

		.preview {
			width: 100%;
			background: #0a0d12;
			border: 1px solid #2a2f38;
			border-radius: 12px;
			min-height: 380px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: auto;
		}

		.preview img {
			max-width: 100%;
			height: auto;
			display: none;
		}

		#status {
			color: #9da7b8;
			font-size: 0.9rem;
			margin-top: 0.25rem;
			min-height: 20px;
		}

		@media (max-width: 900px) {
			.chart-maker-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</head>
<body>
	<div class="chart-maker-wrap">
		<h1><%= title %></h1>
		<p><%= message %></p>

		<div class="chart-maker-grid">
			<div class="card">
				<h2>Chart Inputs</h2>
				<form id="chartMakerForm">
					<div class="field">
						<label for="template">Template</label>
						<select id="template" name="template">
							<option value="large.png" selected>large.png</option>
							<option value="medium.png">medium.png</option>
						</select>
					</div>

					<div class="field">
						<label for="airportName">Airport Name</label>
						<input id="airportName" name="airportName" value="Shork Airport" required />
					</div>

					<div class="field">
						<label for="airportAbbr">Airport Abbreviation</label>
						<input id="airportAbbr" name="airportAbbr" value="ABRV" required />
					</div>

					<div class="field">
						<label for="cityState">City, State</label>
						<input id="cityState" name="cityState" value="City, State" required />
					</div>

					<div class="field">
						<label for="airportCode">Chart Code</label>
						<input id="airportCode" name="airportCode" value="AL-289 (FAA)" required />
					</div>

					<div class="field">
						<label for="runways">Runways (one per line)</label>
						<textarea id="runways" name="runways" required>35
17</textarea>
					</div>

					<div class="field">
						<label for="callsign">Airport Frequency Line</label>
						<input id="callsign" name="callsign" value="Shork Airbase:241.5" required />
					</div>

					<div class="field">
						<label for="generalFrequency">General Frequency Line</label>
						<input id="generalFrequency" name="generalFrequency" value="General: 254.0" required />
					</div>

					<button type="submit">Generate PNG</button>
					<button id="downloadBtn" type="button" disabled>Download PNG</button>
					<p id="status"></p>
				</form>
			</div>

			<div class="card">
				<h2>Preview</h2>
				<div class="preview">
					<img id="chartPreview" alt="Generated airport chart preview" />
					<span id="previewPlaceholder">Your generated PNG will appear here.</span>
				</div>
			</div>
		</div>
	</div>

	<script>
		const form = document.getElementById('chartMakerForm');
		const statusText = document.getElementById('status');
		const chartPreview = document.getElementById('chartPreview');
		const placeholder = document.getElementById('previewPlaceholder');
		const downloadBtn = document.getElementById('downloadBtn');

		let currentImageData = null;
		let currentFilename = 'airport-diagram.png';

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			statusText.textContent = 'Generating chart PNG...';
			downloadBtn.disabled = true;

			const formData = new FormData(form);
			const payload = Object.fromEntries(formData.entries());

			const runwaysText = payload.runways || '';
			payload.runways = runwaysText
				.split('\n')
				.map(r => r.trim())
				.filter(r => r.length > 0);

			if (payload.runways.length === 0) {
				statusText.textContent = 'Error: At least one runway is required.';
				return;
			}

			try {
				const response = await fetch('/api/chart-maker/generate', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify(payload)
				});

				const result = await response.json();
				if (!response.ok) {
					throw new Error(result.error || 'Failed to generate chart.');
				}

				currentImageData = result.imageData;
				currentFilename = result.filename || 'airport-diagram.png';

				chartPreview.src = currentImageData;
				chartPreview.style.display = 'block';
				placeholder.style.display = 'none';
				downloadBtn.disabled = false;
				statusText.textContent = 'Chart PNG generated successfully.';
			} catch (error) {
				statusText.textContent = 'Error: ' + error.message;
				downloadBtn.disabled = true;
			}
		});

		downloadBtn.addEventListener('click', () => {
			if (!currentImageData) return;
			const link = document.createElement('a');
			link.href = currentImageData;
			link.download = currentFilename;
			document.body.appendChild(link);
			link.click();
			link.remove();
		});
	</script>
</body>
</html>
