<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta http-equiv="X-UA-Compatible" content="ie=edge">
	<meta name="author" content="Caleb Thomas (TheRavenSeb)">
	<meta name="description" content="Reset your Aviation Realism Network account password.">
	<meta name="keywords" content="Forgot Password, Reset Password, ATC, Aviation, Discord, Vtol VR">
	<title>Forgot Password</title>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		body {
			font-family: Arial, sans-serif;
			background-color: #1e1e1e;
			color: #e0e0e0;
			min-height: 100vh;
			display: flex;
			flex-direction: row;
			padding: 0;
			margin: 0;
		}

		.main-content {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 20px;
			overflow-y: auto;
			min-height: 100vh;
			width: calc(100% - 280px);
		}

		.sidebar {
			width: 280px;
			background-color: #2a2a2a;
			border-right: 1px solid #444;
			padding: 30px 20px;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 25px;
			overflow-y: auto;
			position: fixed;
			left: 0;
			top: 0;
			height: 100vh;
			z-index: 999;
			transition: transform 0.3s ease-in-out;
		}

		.sidebar.active {
			transform: translateX(0);
		}

		.sidebar-logo {
			width: 120px;
			height: 120px;
			background-color: #e0e0e0;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 60px;
			color: #2a2a2a;
		}

		.sidebar-logo img {
			width: 100%;
			height: 100%;
			border-radius: 50%;
			object-fit: cover;
		}

		.sidebar-title {
			text-align: center;
			color: #e0e0e0;
			font-size: 1.3em;
			font-weight: bold;
			line-height: 1.3;
		}

		.sidebar-title a {
			color: #e0e0e0;
			text-decoration: none;
		}

		.sidebar-title a:hover {
			color: #667eea;
		}

		.sidebar-menu {
			width: 100%;
			display: flex;
			flex-direction: column;
			gap: 3px;
		}

		.sidebar-menu-item {
			padding: 12px 16px;
			color: #b0b0b0;
			text-decoration: none;
			border-radius: 6px;
			cursor: pointer;
			transition: all 0.2s;
			text-align: left;
			font-size: 0.95em;
		}

		.sidebar-menu-item:hover {
			background-color: #3a3a3a;
			color: #e0e0e0;
		}

		.sidebar-menu-item.active {
			background-color: #667eea;
			color: #ffffff;
		}

		.header-container {
			width: 100%;
			display: flex;
			align-items: center;
			gap: 15px;
			margin-bottom: 20px;
		}

		.hamburger-btn {
			display: none;
			background: none;
			border: none;
			color: #e0e0e0;
			font-size: 1.5em;
			cursor: pointer;
			margin-right: 15px;
			transition: all 0.2s;
			padding: 10px 0;
		}

		.hamburger-btn:hover,
		.hamburger-btn.active {
			color: #667eea;
		}

		.close-sidebar-btn {
			display: none;
			position: absolute;
			top: 15px;
			right: 15px;
			background: none;
			border: none;
			color: #e0e0e0;
			font-size: 28px;
			cursor: pointer;
			padding: 0;
			width: 30px;
			height: 30px;
			z-index: 1002;
		}

		.close-sidebar-btn:hover {
			color: #667eea;
		}

		header {
			text-align: center;
			color: #e0e0e0;
			margin-bottom: 30px;
		}

		header h1 {
			font-size: 2.2em;
			margin-bottom: 8px;
		}

		header p {
			font-size: 1.05em;
			opacity: 0.9;
		}

		.reset-panel {
			background: #333;
			border-radius: 12px;
			padding: 35px;
			box-shadow: 0 10px 30px rgba(0,0,0,0.2);
			width: 100%;
			max-width: 460px;
		}

		.reset-panel h2 {
			color: #e0e0e0;
			font-size: 1.4em;
			margin-bottom: 22px;
			text-align: center;
			border-bottom: 2px solid #667eea;
			padding-bottom: 14px;
		}

		.step-indicator {
			display: flex;
			justify-content: space-between;
			gap: 8px;
			margin-bottom: 22px;
		}

		.step-pill {
			flex: 1;
			text-align: center;
			font-size: 0.8em;
			padding: 7px 8px;
			border-radius: 999px;
			background: #2a2a2a;
			color: #a8a8a8;
			border: 1px solid #444;
		}

		.step-pill.active {
			background: #667eea;
			color: #fff;
			border-color: #667eea;
		}

		.step-pill.complete {
			background: #2f6548;
			color: #dcffe9;
			border-color: #3f8f66;
		}

		.form-step {
			display: none;
		}

		.form-step.active {
			display: block;
		}

		.form-group {
			margin-bottom: 18px;
		}

		.form-group label {
			display: block;
			margin-bottom: 8px;
			font-weight: bold;
			color: #e0e0e0;
		}

		.form-group input {
			width: 100%;
			padding: 12px;
			background-color: #2a2a2a;
			border: 1px solid #444;
			border-radius: 4px;
			color: #e0e0e0;
			font-family: Arial, sans-serif;
			font-size: 1em;
		}

		.form-group input:focus {
			outline: none;
			border-color: #667eea;
			background-color: #323232;
		}

		.hint {
			font-size: 0.88em;
			color: #b0b0b0;
			margin-top: -4px;
			margin-bottom: 16px;
		}

		.form-actions {
			display: flex;
			gap: 10px;
			margin-top: 18px;
		}

		.form-actions button {
			flex: 1;
			padding: 12px;
			border: none;
			border-radius: 4px;
			cursor: pointer;
			font-size: 1em;
			font-weight: bold;
			transition: all 0.2s;
		}

		.submit-btn {
			background-color: #667eea;
			color: white;
		}

		.submit-btn:hover {
			background-color: #5568d3;
		}

		.secondary-btn {
			background-color: #3f3f3f;
			color: #e8e8e8;
			border: 1px solid #555;
		}

		.secondary-btn:hover {
			background-color: #4a4a4a;
		}

		.error-message,
		.success-message,
		.info-message {
			padding: 12px;
			border-radius: 4px;
			margin-bottom: 16px;
			display: none;
			font-size: 0.95em;
		}

		.error-message {
			background-color: #f44336;
			color: white;
		}

		.success-message {
			background-color: #2e7d32;
			color: white;
		}

		.info-message {
			background-color: #304a72;
			color: #e3ecff;
			border: 1px solid #456295;
		}

		.login-link {
			text-align: center;
			margin-top: 18px;
			color: #b0b0b0;
		}

		.login-link a {
			color: #667eea;
			text-decoration: none;
			font-weight: bold;
		}

		.login-link a:hover {
			color: #7c8ff0;
		}

		footer {
			color: white;
			margin-top: 34px;
			text-align: center;
			opacity: 0.8;
		}

		@media (max-width: 768px) {
			body {
				flex-direction: column;
			}

			.hamburger-btn {
				display: block;
			}

			.main-content {
				width: 100%;
				padding: 15px;
				align-items: center;
			}

			.sidebar {
				width: 250px;
				position: fixed;
				top: 0;
				left: 0;
				transform: translateX(-100%);
				padding: 70px 20px 20px 20px;
				z-index: 1001;
				max-height: 100vh;
				overflow-y: auto;
				border-right: 1px solid #444;
				transition: transform 0.3s ease-in-out;
			}

			.sidebar.active {
				transform: translateX(0);
			}

			.close-sidebar-btn {
				display: block;
			}

			.reset-panel {
				padding: 24px;
				width: 100%;
			}

			header h1 {
				font-size: 1.8em;
			}
		}

		@media (max-width: 480px) {
			.main-content {
				padding: 12px;
			}

			.reset-panel {
				padding: 18px;
				max-width: 100%;
				width: 100%;
			}

			header {
				margin-bottom: 20px;
			}

			header h1 {
				font-size: 1.45em;
			}

			.reset-panel h2 {
				font-size: 1.2em;
				margin-bottom: 18px;
			}

			.form-group input {
				font-size: 16px;
			}

			.step-pill {
				font-size: 0.73em;
				padding: 6px 5px;
			}
		}
	</style>
</head>
<body>
	<div class="sidebar" id="sidebar">
		<button type="button" class="close-sidebar-btn" id="closeSidebarBtn" onclick="closeSidebar()" aria-label="Close sidebar">✕</button>
		<div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
		<div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
		<div class="sidebar-menu">
			<a class="sidebar-menu-item" href="/">Home</a>
			<a class="sidebar-menu-item" href="/pilots">Pilots</a>
			<a class="sidebar-menu-item active" href="/forgot-password">Forgot Password</a>
			<a class="sidebar-menu-item" href="/login/home">Login</a>
			<a class="sidebar-menu-item" href="/register">Register</a>
			<a class="sidebar-menu-item" href="/information">Information</a>
		</div>
	</div>

	<div class="main-content">
		<div class="header-container">
			<button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Toggle sidebar">☰</button>
		</div>

		<header>
			<h1>Forgot Password</h1>
			<p>Recover your account with a verification code</p>
		</header>

		<div class="reset-panel">
			<h2>Reset Password</h2>

			<div class="step-indicator">
				<div class="step-pill active" id="pill1">1. Email</div>
				<div class="step-pill" id="pill2">2. Verify Code</div>
				<div class="step-pill" id="pill3">3. New Password</div>
			</div>

			<div class="error-message" id="errorMessage"></div>
			<div class="success-message" id="successMessage"></div>
			<div class="info-message" id="infoMessage"></div>

			<div class="form-step active" id="step1">
				<form id="requestCodeForm">
					<div class="form-group">
						<label for="email">Account Email:</label>
						<input type="email" id="email" name="email" required autocomplete="email">
					</div>
					<p class="hint">We’ll send a 6-digit verification code to your email.</p>
					<div class="form-actions">
						<button type="submit" class="submit-btn">Send Code</button>
					</div>
				</form>
			</div>

			<div class="form-step" id="step2">
				<form id="verifyCodeForm">
					<div class="form-group">
						<label for="code">Verification Code:</label>
						<input type="text" id="code" name="code" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code">
					</div>
					<p class="hint">Enter the 6-digit code you received.</p>
					<div class="form-actions">
						<button type="button" class="secondary-btn" id="backToEmailBtn">Back</button>
						<button type="submit" class="submit-btn">Verify Code</button>
					</div>
				</form>
			</div>

			<div class="form-step" id="step3">
				<form id="resetPasswordForm">
					<div class="form-group">
						<label for="newPassword">New Password:</label>
						<input type="password" id="newPassword" name="newPassword" required minlength="8" autocomplete="new-password">
					</div>
					<div class="form-group">
						<label for="confirmPassword">Confirm New Password:</label>
						<input type="password" id="confirmPassword" name="confirmPassword" required minlength="8" autocomplete="new-password">
					</div>
					<p class="hint">Use at least 8 characters for stronger security.</p>
					<div class="form-actions">
						<button type="button" class="secondary-btn" id="backToCodeBtn">Back</button>
						<button type="submit" class="submit-btn">Reset Password</button>
					</div>
				</form>
			</div>

			<div class="login-link">
				Remembered your password? <a href="/login/home">Back to login</a>
			</div>
		</div>

		<footer>
			<p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
		</footer>
	</div>

	<script>
		const step1 = document.getElementById('step1');
		const step2 = document.getElementById('step2');
		const step3 = document.getElementById('step3');

		const pill1 = document.getElementById('pill1');
		const pill2 = document.getElementById('pill2');
		const pill3 = document.getElementById('pill3');

		const errorMessage = document.getElementById('errorMessage');
		const successMessage = document.getElementById('successMessage');
		const infoMessage = document.getElementById('infoMessage');

		let resetState = {
			email: '',
			code: ''
		};

		function setStep(step) {
			step1.classList.remove('active');
			step2.classList.remove('active');
			step3.classList.remove('active');

			pill1.classList.remove('active', 'complete');
			pill2.classList.remove('active', 'complete');
			pill3.classList.remove('active', 'complete');

			if (step === 1) {
				step1.classList.add('active');
				pill1.classList.add('active');
			}

			if (step === 2) {
				step2.classList.add('active');
				pill1.classList.add('complete');
				pill2.classList.add('active');
			}

			if (step === 3) {
				step3.classList.add('active');
				pill1.classList.add('complete');
				pill2.classList.add('complete');
				pill3.classList.add('active');
			}
		}

		function clearMessages() {
			errorMessage.style.display = 'none';
			successMessage.style.display = 'none';
			infoMessage.style.display = 'none';
			errorMessage.textContent = '';
			successMessage.textContent = '';
			infoMessage.textContent = '';
		}

		function showError(message) {
			clearMessages();
			errorMessage.textContent = message;
			errorMessage.style.display = 'block';
		}

		function showSuccess(message) {
			clearMessages();
			successMessage.textContent = message;
			successMessage.style.display = 'block';
		}

		function showInfo(message) {
			clearMessages();
			infoMessage.textContent = message;
			infoMessage.style.display = 'block';
		}

		document.getElementById('requestCodeForm').addEventListener('submit', async function(e) {
			e.preventDefault();
			clearMessages();

			const emailValue = document.getElementById('email').value.trim();
			if (!emailValue) {
				return showError('Please enter your email address.');
			}

			try {
				const response = await fetch('/api/auth/forgot-password/request-code', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email: emailValue })
				});

				const data = await response.json();
				if (!response.ok || data.error) {
					return showError(data.error || 'Unable to send verification code. Please try again.');
				}

				resetState.email = emailValue;
				setStep(2);
				showSuccess(data.message || 'If an account exists for that email, a verification code has been sent.');

				if (data.developmentCode) {
					showInfo(`Development mode code: ${data.developmentCode}`);
				}
			} catch (err) {
				console.error('Request code error:', err);
				showError('Error sending verification code. Please try again.');
			}
		});

		document.getElementById('verifyCodeForm').addEventListener('submit', async function(e) {
			e.preventDefault();
			clearMessages();

			const codeValue = document.getElementById('code').value.trim();
			if (!/^[0-9]{6}$/.test(codeValue)) {
				return showError('Please enter a valid 6-digit code.');
			}

			try {
				const response = await fetch('/api/auth/forgot-password/verify-code', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						email: resetState.email,
						code: codeValue
					})
				});

				const data = await response.json();
				if (!response.ok || data.error) {
					return showError(data.error || 'Invalid or expired code.');
				}

				resetState.code = codeValue;
				setStep(3);
				showSuccess('Code verified. You can now set a new password.');
			} catch (err) {
				console.error('Verify code error:', err);
				showError('Error verifying code. Please try again.');
			}
		});

		document.getElementById('resetPasswordForm').addEventListener('submit', async function(e) {
			e.preventDefault();
			clearMessages();

			const newPassword = document.getElementById('newPassword').value;
			const confirmPassword = document.getElementById('confirmPassword').value;

			if (newPassword.length < 8) {
				return showError('Password must be at least 8 characters long.');
			}

			if (newPassword !== confirmPassword) {
				return showError('Passwords do not match.');
			}

			try {
				const response = await fetch('/api/auth/forgot-password/reset', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						email: resetState.email,
						code: resetState.code,
						newPassword
					})
				});

				const data = await response.json();
				if (!response.ok || data.error) {
					return showError(data.error || 'Could not reset password.');
				}

				showSuccess('Password reset successful! Redirecting to login...');
				setTimeout(() => {
					window.location.href = '/login/home';
				}, 1800);
			} catch (err) {
				console.error('Reset password error:', err);
				showError('Error resetting password. Please try again.');
			}
		});

		document.getElementById('backToEmailBtn').addEventListener('click', function() {
			clearMessages();
			setStep(1);
		});

		document.getElementById('backToCodeBtn').addEventListener('click', function() {
			clearMessages();
			setStep(2);
		});

		function toggleSidebar() {
			const sidebar = document.getElementById('sidebar');
			const hamburgerBtn = document.getElementById('hamburgerBtn');
			const closeBtn = document.getElementById('closeSidebarBtn');
			sidebar.classList.toggle('active');
			hamburgerBtn.classList.toggle('active');
			closeBtn.style.display = sidebar.classList.contains('active') ? 'block' : 'none';
		}

		function closeSidebar() {
			const sidebar = document.getElementById('sidebar');
			const hamburgerBtn = document.getElementById('hamburgerBtn');
			const closeBtn = document.getElementById('closeSidebarBtn');
			sidebar.classList.remove('active');
			hamburgerBtn.classList.remove('active');
			closeBtn.style.display = 'none';
		}

		document.addEventListener('DOMContentLoaded', function() {
			const sidebarMenuItems = document.querySelectorAll('.sidebar-menu-item');
			sidebarMenuItems.forEach(item => {
				item.addEventListener('click', function() {
					if (window.innerWidth <= 768) {
						closeSidebar();
					}
				});
			});
		});

		window.addEventListener('click', function(event) {
			const sidebar = document.getElementById('sidebar');
			const hamburgerBtn = document.getElementById('hamburgerBtn');
			if (!sidebar.contains(event.target) && !hamburgerBtn.contains(event.target) && sidebar.classList.contains('active')) {
				closeSidebar();
			}
		});
	</script>
</body>
</html>
